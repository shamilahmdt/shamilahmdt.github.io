---

---

<section
  id="about"
  class="w-full sm:w-[85%] mx-auto pb-44 mt-[15vh] relative z-10"
>
  <div class="pop text-center pt-14">
    <h2 class="text-3xl md:text-4xl font-bold mb-3 text-white">About Me</h2>
    <div class="w-24 h-1 bg-gradient-to-r from-cyan-500 to-blue-600 mx-auto">
    </div>
  </div>

  <div
    class="pop w-auto rounded-[32px] mt-8 border-white/10 h-auto backdrop-blur-md bg-white/5 border overflow-hidden"
  >
    <div class="text-white p-6 sm:p-10 md:p-12">
      <div class="grid md:grid-cols-2 gap-10 md:gap-16 items-start">
        <div>
          <h3 class="text-2xl font-bold mb-6 bg-gradient-to-r from-cyan-400 to-blue-500 text-transparent bg-clip-text">
            Professional Summary
          </h3>
          <p
            class="text-[15px] sm:text-[17px] leading-relaxed mb-6 text-gray-200 text-left md:text-justify"
          >
            Hello! I'm <span class="font-bold">Shamil Ahammed T</span>, a dedicated Python Full Stack Developer
            with a passion for creating innovative digital solutions. With
            hands-on experience at leading tech companies and a strong academic
            foundation, I bring both theoretical knowledge and practical
            expertise to every project.
          </p>
          <p
            class="text-[15px] sm:text-[17px] leading-relaxed mb-8 text-gray-200 text-left md:text-justify"
          >
            I specialize in building robust web applications using modern
            technologies like Django, React, and PostgreSQL. My approach
            combines clean code practices with user-centered design to deliver
            solutions that are both functional and engaging.
          </p>
          <div class="grid grid-cols-2 gap-4 mb-2">
            <div
              class="text-center p-5 rounded-2xl border-white/5 bg-white/5 border hover:border-cyan-500/30 transition-colors"
            >
              <div
                class="text-2xl font-extrabold bg-gradient-to-r from-cyan-500 to-blue-500 text-transparent bg-clip-text"
              >
                3+
              </div>
              <div class="text-xs sm:text-sm text-gray-400 mt-1 uppercase tracking-wider font-semibold">Months Exp.</div>
            </div>
            <div
              class="text-center p-5 rounded-2xl border-white/5 bg-white/5 border hover:border-cyan-500/30 transition-colors"
            >
              <div
                class="text-2xl font-extrabold bg-gradient-to-r from-cyan-500 to-blue-500 text-transparent bg-clip-text"
              >
                5+
              </div>
              <div class="text-xs sm:text-sm text-gray-400 mt-1 uppercase tracking-wider font-semibold">Projects Done</div>
            </div>
          </div>
        </div>
        <div class="space-y-8">
          <div
            class="backdrop-blur-xl bg-black/20 border-white/10 rounded-2xl p-6 border hover:bg-black/30 transition-all group"
          >
            <div
              class="flex items-center mb-4 text-2xl font-extrabold bg-gradient-to-r from-cyan-500 to-blue-500 text-transparent bg-clip-text"
            >
              <svg class="w-6 h-6 mr-3 text-cyan-500 group-hover:scale-110 transition-transform" fill="currentColor" viewBox="0 0 24 24"><path d="M12 3L1 9l11 6 9-4.91V17h2V9L12 3zM3.89 9.57l8.11 4.42 8.11-4.42-8.11-4.42-8.11 4.42zM12 16.5l-6-3.27V17l6 3.27 6-3.27v-3.77l-6 3.27z"/></svg>
              <h4 class="font-bold">Education</h4>
            </div>
            <div class="border-l-2 border-cyan-500/30 pl-4 space-y-1">
              <p class="text-gray-100 font-semibold text-base sm:text-lg">
                B.Tech in Computer Science Engineering
              </p>
              <p class="text-sm text-gray-400">
                MGM College of Engineering & Technology
              </p>
              <p class="text-xs text-gray-500 font-medium">
                2021 - 2025 | Kerala, India
              </p>
            </div>
          </div>
 
          <div
            class="backdrop-blur-xl bg-black/20 border-white/10 rounded-2xl p-6 border hover:bg-black/30 transition-all group"
          >
            <div
              class="flex items-center mb-4 text-2xl font-extrabold bg-gradient-to-r from-cyan-500 to-blue-500 text-transparent bg-clip-text"
            >
              <svg class="w-6 h-6 mr-3 text-cyan-500 group-hover:scale-110 transition-transform" fill="currentColor" viewBox="0 0 24 24"><path d="M15.5 14h-.79l-.28-.27A6.471 6.471 0 0016 9.5 6.5 6.5 0 109.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"/></svg>
              <h4 class="font-bold">Focus Areas</h4>
            </div>
            <ul class="space-y-3 pl-4 border-l-2 border-cyan-500/30 text-gray-300">
              <li class="flex items-center text-sm sm:text-base font-medium">
                <span class="w-1.5 h-1.5 rounded-full bg-cyan-500 mr-3"></span>
                Full Stack Development
              </li>
              <li class="flex items-center text-sm sm:text-base font-medium">
                <span class="w-1.5 h-1.5 rounded-full bg-cyan-500 mr-3"></span>
                Front End Development
              </li>
              <li class="flex items-center text-sm sm:text-base font-medium">
                <span class="w-1.5 h-1.5 rounded-full bg-cyan-500 mr-3"></span>
                Backend Development
              </li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
