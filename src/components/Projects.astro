---
import { Image } from 'astro:assets';
import evTwo from '../assets/images/ev/two.png';
import evFour from '../assets/images/ev/four.png';
import evThree from '../assets/images/ev/three.png';
import foodz2 from '../assets/images/foodz/2.png';
import foodz3 from '../assets/images/foodz/3.png';
import foodz4 from '../assets/images/foodz/4.png';
import todo1 from '../assets/images/todo/1.png';
import todo2 from '../assets/images/todo/2.png';
import todo3 from '../assets/images/todo/3.png';

const projects = [
  {
    title: "EV Charging Station Slot Booking",
    tech: "HTML | TailwindCSS | Django",
    images: [evTwo, evFour, evThree],
    github: "https://github.com/shamilahmdt/EV_Charging_Slot_Booking"
  },
  {
    title: "FOODZ",
    tech: "DJANGO | API | TailwindCSS",
    images: [foodz2, foodz3, foodz4],
    github: "https://github.com/shamilahmdt/FOODZ"
  },
  {
    title: "TO-DO List",
    tech: "HTML | JS | TailwindCSS",
    images: [todo1, todo2, todo3],
    github: "https://github.com/shamilahmdt/To-do-list"
  }
];
---

<section id="projects" class="w-full sm:w-[85%] mx-auto h-auto text-center pb-44 relative z-10">
  <div class="pop text-center pt-9 mt-3">
    <h2 class="text-3xl md:text-4xl font-bold mb-3 text-white">Projects</h2>
    <div class="w-16 h-1 bg-gradient-to-r from-cyan-500 to-blue-600 mx-auto"></div>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 mt-12 gap-8 place-items-center">
    {projects.map((project) => (
      <div class="relative group w-full max-w-[350px] h-[220px] overflow-hidden rounded-xl shadow-lg">
        <div class="project-slider w-full h-full relative">
          {project.images.map((img, idx) => (
            <Image 
              src={img} 
              alt={`Screenshot of ${project.title}`} 
              class={`absolute w-full h-full object-cover fade ${idx === 0 ? '' : 'hidden mobile-hide-extra'}`} 
              width={400} 
              height={250} 
              widths={[300, 600]}
              sizes="(max-width: 640px) 100vw, 400px"
              loading="lazy" 
              decoding="async"
            />
          ))}
        </div>

        <div class="absolute inset-0 bg-black/60 opacity-0 group-hover:opacity-100 flex items-center justify-center gap-8 transition-all duration-300 z-20">
          <div class="relative group/icon">
            <a href={project.github} target="_blank" class="text-white hover:scale-110 transition-transform inline-block" aria-label={`View ${project.title} on GitHub`} rel="noopener noreferrer">
              <svg class="w-8 h-8 fill-current" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.041-1.416-4.041-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
            </a>
            <span class="absolute -bottom-8 left-1/2 -translate-x-1/2 bg-gray-800 text-white text-xs px-2 py-1 rounded opacity-0 group-hover/icon:opacity-100 transition whitespace-nowrap">GitHub</span>
          </div>
          {/* <div class="relative group/icon">
             <img src="/images/Details.png" class="w-10 h-10 rounded-full hover:scale-110 transition-transform cursor-help" alt="Details">
            <span class="absolute -bottom-8 left-1/2 -translate-x-1/2 bg-gray-800 text-white text-xs px-2 py-1 rounded opacity-0 group-hover/icon:opacity-100 transition whitespace-nowrap">Details</span>
          </div> */}
        </div>

        <div class="absolute bottom-0 left-0 right-0 bg-black/40 backdrop-blur-md text-white p-3 text-center transition-all duration-300 group-hover:translate-y-full z-10">
          <h3 class="text-lg font-bold leading-tight">{project.title}</h3>
          <p class="text-xs text-black font-medium uppercase tracking-wider mt-1">{project.tech}</p>
        </div>
      </div>
    ))}
  </div>
</section>

<script>
  // Optimized project slider for mobile/performance
  const isMobile = !window.matchMedia('(hover: hover)').matches;
  
  if (!isMobile) {
    document.querySelectorAll('.project-slider').forEach(el => {
      const slider = el as HTMLElement;
      const slides = slider.querySelectorAll('img');
      if (slides.length <= 1) return;
      
      let index = 0;
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            slider.dataset.active = "true";
          } else {
            slider.dataset.active = "false";
          }
        });
      }, { threshold: 0.1 });
      
      observer.observe(slider);

      setInterval(() => {
        if (slider.dataset.active === "true") {
          slides[index].classList.add('hidden');
          index = (index + 1) % slides.length;
          slides[index].classList.remove('hidden');
        }
      }, 4000); // 4s interval for less CPU load
    });
  }
</script>
