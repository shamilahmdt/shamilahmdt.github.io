---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Page Not Found | Redirecting...">
  <div class="flex flex-col items-center justify-center min-h-[70vh] text-center px-4">
    <h1 class="text-4xl font-bold mb-4 bg-gradient-to-r from-cyan-400 to-blue-500 text-transparent bg-clip-text">
      Page Not Found
    </h1>
    <p class="text-gray-400 mb-8">Redirecting you back home...</p>
    <div class="w-12 h-12 border-4 border-cyan-500/30 border-t-cyan-500 rounded-full animate-spin"></div>
  </div>

  <script is:inline>
    // Automatically redirect to home after 1 second
    setTimeout(() => {
      window.location.href = '/';
    }, 1000);
  </script>
</Layout>
